{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?path=:path*"
    },
    {
      "source": "/driver",
      "destination": "/driver.html"
    },
    {
      "source": "/dispatcher",
      "destination": "/dispatcher.html"
    },
    {
      "source": "/tracking",
      "destination": "/tracking.html"
    },
    {
      "source": "/payment",
      "destination": "/payment.html"
    },
    {
      "source": "/gateway",
      "destination": "/gateway.html"
    },
    {
      "source": "/auth",
      "destination": "/auth.html"
    }
  ]
}
